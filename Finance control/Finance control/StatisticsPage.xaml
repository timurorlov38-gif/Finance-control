<Page x:Class="Финансовый_трекер.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Статистика" 
      Background="#F5F7FA">

    <Border CornerRadius="10" Padding="20" Margin="20" Background="White">
        <StackPanel>
            <TextBlock Text="📊 Статистика операций" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="TotalTransactionsText" 
                       Text="Всего транзакций: 0" 
                       FontSize="16" 
                       Margin="0,10"/>

            <TextBlock x:Name="TotalIncomeText" 
                       Text="Общий доход: 0 ₽" 
                       FontSize="16" 
                       Margin="0,10"
                       Foreground="Green"/>

            <TextBlock x:Name="TotalExpenseText" 
                       Text="Общий расход: 0 ₽" 
                       FontSize="16" 
                       Margin="0,10"
                       Foreground="Red"/>

            <Button Content="← Вернуться назад" 
                    Click="BackButton_Click"
                    Margin="0,30,0,0"
                    Padding="15,8"
                    Background="#3498DB"
                    Foreground="White"
                    Cursor="Hand"/>
        </StackPanel>
    </Border>
</Page>