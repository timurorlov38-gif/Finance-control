<Window x:Class="Finance_control.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Финансовый трекер - Версия 2" 
        Height="750" 
        Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Синяя карточка общего баланса -->
            <Border Grid.Row="0" Background="#3498DB" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Автор: Орлов Тимур Юрьевич" 
                               Foreground="White" 
                               FontSize="11" 
                               FontStyle="Italic"
                               Margin="0,0,0,3"/>
                    <TextBlock Text="💰 Общий баланс" Foreground="White" FontSize="14" FontWeight="Bold"/>
                    <TextBlock x:Name="BalanceText" Text="0 ₽" Foreground="White" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Панель кошельков -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="💼 Мои кошельки" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Margin="0,0,0,8"
                               Foreground="#2C3E50"/>

                    <ItemsControl x:Name="WalletsList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F9FA" 
                                        CornerRadius="5" 
                                        Padding="10" 
                                        Margin="0,0,0,5"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1">
                                    <DockPanel LastChildFill="False">
                                        <TextBlock Text="{Binding Icon}" 
                                                   FontSize="18" 
                                                   DockPanel.Dock="Left" 
                                                   Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Name}" 
                                                   FontWeight="Bold" 
                                                   FontSize="12"
                                                   DockPanel.Dock="Left"
                                                   Margin="0,0,15,0"
                                                   Foreground="#34495E"/>
                                        <TextBlock Text="{Binding Balance, StringFormat={}{0:N0} ₽}" 
                                                   FontWeight="Bold" 
                                                   FontSize="13"
                                                   DockPanel.Dock="Right"
                                                   Foreground="#3498DB"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="#9B59B6" 
                            CornerRadius="5" 
                            Padding="10" 
                            Margin="0,5,0,0">
                        <DockPanel>
                            <TextBlock Text="📊 Общий баланс:" 
                                       FontSize="12" 
                                       Foreground="White" 
                                       FontWeight="Bold"
                                       DockPanel.Dock="Left"/>
                            <TextBlock x:Name="TotalWalletsBalanceText" 
                                       Text="0 ₽" 
                                       FontSize="14" 
                                       Foreground="White" 
                                       FontWeight="Bold"
                                       DockPanel.Dock="Right"/>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- PIN-защита -->
            <Border Grid.Row="2" Background="#ECF0F1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                <WrapPanel>
                    <Label Content="🔒 PIN:" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                    <PasswordBox x:Name="PinBox" Width="120" Margin="5,0" VerticalAlignment="Center" Height="25"/>
                    <Image x:Name="LockImage" Width="20" Height="20" Margin="5,0" Cursor="Hand" MouseLeftButtonDown="LockImage_MouseLeftButtonDown">
                        <Image.Source>
                            <BitmapImage UriSource="Resources/padlock.png"/>
                        </Image.Source>
                    </Image>
                    <TextBlock x:Name="SecurityStatus" Text="Разблокировано" Foreground="Green" VerticalAlignment="Center" Margin="5,0"/>
                    <Button Content="Сбросить PIN" Click="ResetPin_Click" Width="90" Margin="5,0" Height="25"/>
                    <Button Content="📊 Статистика" Click="ShowStatistics_Click" Width="120" Background="#9B59B6" Foreground="White" Margin="10,0,0,0" Height="25"/>
                </WrapPanel>
            </Border>

            <!-- Основная часть -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая колонка - Форма транзакции -->
                <GroupBox Grid.Column="0" Header="📝 Новая транзакция" Margin="0,0,5,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8">
                            <Label Content="Сумма (₽):" FontWeight="Bold" FontSize="11"/>
                            <TextBox x:Name="AmountBox" Margin="0,0,0,8" Padding="5" Height="25"/>

                            <Label Content="Описание:" FontWeight="Bold" FontSize="11"/>
                            <TextBox x:Name="DescriptionBox" Margin="0,0,0,8" Padding="5" Height="25"/>

                            <CheckBox x:Name="IsIncomeCheckBox" Content="✓ Это доход" Margin="0,0,0,8" FontSize="11"/>

                            <Label Content="Кошелек:" FontWeight="Bold" FontSize="11"/>
                            <ComboBox x:Name="WalletComboBox" 
                                      Margin="0,0,0,8" 
                                      SelectionChanged="WalletComboBox_SelectionChanged"
                                      Height="25">
                                <ComboBoxItem Content="💳 Основной" IsSelected="True"/>
                                <ComboBoxItem Content="💰 Наличные"/>
                                <ComboBoxItem Content="🏦 Сберегательный"/>
                            </ComboBox>

                            <TextBlock x:Name="WalletBalanceText" 
                                       Text="Баланс: 0 ₽" 
                                       FontSize="11" 
                                       FontWeight="Bold" 
                                       Margin="0,0,0,8"
                                       Foreground="#3498DB"/>

                            <Button Content="+ Добавить" Click="AddTransaction_Click" Background="#27AE60" Foreground="White" Padding="8,5" Margin="0,0,0,8" Height="30" FontWeight="Bold"/>

                            <Label Content="📊 Лимит расходов:" FontWeight="Bold" FontSize="11"/>
                            <Slider x:Name="LimitSlider" Minimum="1000" Maximum="100000" Value="30000" TickFrequency="1000" IsSnapToTickEnabled="True" Margin="0,0,0,5"/>
                            <TextBlock x:Name="LimitValueText" Text="Лимит: 30 000 ₽" FontWeight="ExtraBlack" Foreground="Red" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ScrollViewer>
                </GroupBox>

                <!-- Правая колонка - История -->
                <GroupBox Grid.Column="1" Header="📜 История операций" Margin="5,0,0,0">
                    <ScrollViewer x:Name="TransactionsScroll" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="TransactionsList"/>
                    </ScrollViewer>
                </GroupBox>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>