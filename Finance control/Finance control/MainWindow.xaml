<Window x:Class="Финансовый_трекер.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Финансовый трекер - Версия 1" Height="700" Width="1000"
        Background="#F5F7FA" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. Баланс -->
        <Border Grid.ColumnSpan="2" Background="#3498DB" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="💰 Общий баланс" Foreground="White" FontSize="16" Opacity="0.9"/>
                <TextBlock x:Name="BalanceText" Text="0 ₽" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- 2. DockPanel - Панель безопасности -->
        <Border Grid.ColumnSpan="2" Grid.Row="1" Margin="0,0,0,15" Background="#ECF0F1" CornerRadius="5">
            <DockPanel LastChildFill="False" Margin="10">
                <Label Content="🔒 PIN-защита:" DockPanel.Dock="Left" VerticalAlignment="Center" FontWeight="Bold"/>

                <PasswordBox x:Name="PasswordBox" 
                     Width="120" 
                     Margin="5,0" 
                     Height="25"
                     PasswordChanged="PasswordBox_PasswordChanged"
                     ToolTip="Введите PIN-код (1234) для разблокировки"/>

                <!-- Текстовый замок вместо картинки -->
                <Image x:Name="LockImage" 
       Source="Resources/padlock.png"
       Width="25" 
       Height="25" 
       Margin="10,0,5,0"
       MouseLeftButtonDown="LockImage_MouseLeftButtonDown" 
       Cursor="Hand"
       ToolTip="Нажмите для блокировки/разблокировки"
       Stretch="Uniform"/>

                <TextBlock x:Name="SecurityStatus" 
                   Text="Разблокировано" 
                   VerticalAlignment="Center" 
                   Margin="10,0" 
                   FontWeight="Bold" 
                   Foreground="Green"/>

                <Button Content="Сбросить PIN" 
                Click="ResetPin_Click" 
                Margin="10,0,0,0"
                Background="#95A5A6" 
                Foreground="White" 
                Padding="8,3" 
                Cursor="Hand">
                    <Button.ToolTip>
                        <ToolTip Content="Очистить поле PIN-кода"/>
                    </Button.ToolTip>
                </Button>
            </DockPanel>
        </Border>

        <!-- 3. Форма добавления транзакции -->
        <GroupBox Header="📝 Новая транзакция" Grid.Row="2" Grid.Column="0" Padding="15" 
                  BorderBrush="#3498DB" BorderThickness="2" Margin="0,0,10,0">
            <StackPanel>
                <Label Content="Сумма (₽):" FontWeight="Bold"/>
                <TextBox x:Name="AmountBox" FontSize="16" Padding="8" Margin="0,0,0,10" 
                         TextChanged="AmountBox_TextChanged"
                         ToolTip="Введите сумму транзакции"/>

                <Label Content="Описание:" FontWeight="Bold" Margin="0,10,0,0"/>
                <TextBox x:Name="DescriptionBox" FontSize="14" Padding="8" Margin="0,0,0,10"
                         TextChanged="DescriptionBox_TextChanged"
                         ToolTip="Введите описание операции"/>

                <CheckBox x:Name="IncomeCheckBox" Content="✓ Это доход (а не расход)" 
                          FontSize="14" Margin="0,10" Checked="IncomeCheckBox_Checked" 
                          Unchecked="IncomeCheckBox_Unchecked"
                          ToolTip="Отметьте, если это доход"/>

                <Button Content="➕ Добавить транзакцию" Click="AddTransaction_Click" 
                        Background="#27AE60" Foreground="White" FontSize="16" Padding="10" 
                        Margin="0,20,0,0" Cursor="Hand" FontWeight="Bold">
                    <Button.ToolTip>
                        <ToolTip Content="Добавить новую транзакцию в историю"/>
                    </Button.ToolTip>
                </Button>

                <Label Content="📊 Лимит расходов на месяц:" FontWeight="Bold" Margin="0,20,0,0"/>
                <Slider x:Name="LimitSlider" Minimum="1000" Maximum="100000" Value="30000" 
                        TickFrequency="10000" IsSnapToTickEnabled="True" 
                        ValueChanged="LimitSlider_ValueChanged" Margin="0,10,0,5"
                        ToolTip="Установите лимит расходов"/>
                <TextBlock x:Name="LimitValueText" Text="Лимит: 30 000 ₽" HorizontalAlignment="Center" 
                           Foreground="#E74C3C" FontWeight="Bold" FontSize="14" Height="20" Margin="94,0"/>

                <TextBlock x:Name="LimitWarningText" Text="" HorizontalAlignment="Center" 
                           Foreground="Red" FontWeight="Bold" FontSize="12" Margin="0,5,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </GroupBox>

        <!-- 4. История транзакций -->
        <GroupBox Header="📜 История операций" Grid.Column="1" Grid.Row="2" 
                  Padding="10" BorderBrush="#E74C3C" BorderThickness="2" Margin="0,10,0,0">
            <ScrollViewer x:Name="TransactionsScroll" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="TransactionsPanel">
                    <!-- Транзакции будут добавляться сюда динамически -->
                </StackPanel>
            </ScrollViewer>
        </GroupBox>

        <!-- 5. Frame - для статистики -->
        <Frame x:Name="StatsFrame" Grid.Column="1" Grid.Row="0" 
               NavigationUIVisibility="Hidden" Margin="0,0,0,10"
               Visibility="Visible"/>
        <!-- Кнопка для открытия статистики -->
        <Button Content="📊 Показать статистику" 
        Click="ShowStatistics_Click"
        Margin="330,9,10,26"
        Padding="10,8"
        Background="#9B59B6"
        Foreground="White"
        FontSize="14"
        Cursor="Hand" Grid.Column="1" Grid.Row="1">
            <Button.ToolTip>
                <ToolTip Content="Показать статистику в Frame"/>
            </Button.ToolTip>
        </Button>
    </Grid>
</Window>